{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "resume_assistant/Scripts/python scripts/sync-mirrors.py --quiet >/dev/null 2>&1 || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
